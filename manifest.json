{
  "manifest_version": 3,
  "name": "Cats Shields",
  "version": "1.0.1",
  "description": "Filter the web with customizable keywords and replace matched images with local cat photos.",
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["defaults.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Cats Shields",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["cats/*.jpg"],
      "matches": ["<all_urls>"]
    }
  ]
}
